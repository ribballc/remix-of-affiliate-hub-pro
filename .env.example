# Copy to .env and fill in your values. Never commit .env.
# Get credentials from https://partner.tiktokshop.com (Apps & Services)

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TikTok Shop Partner API (for Creator Feed / open collaboration)
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=

# Optional: override API base/path if your Partner doc differs
# TIKTOK_SHOP_API_BASE=https://partner-api.tiktokshop.com
# TIKTOK_SHOP_CREATOR_PATH=/open_api/202309/affiliate/creator/list
